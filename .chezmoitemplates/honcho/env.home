# ==============================================================================
# LLM Provider Configuration - HOME (OpenRouter + Fireworks ONLY)
# ==============================================================================
# NO direct OpenAI/Anthropic/Google API keys - everything routes through:
# - OpenRouter (primary) for Gemini models and embeddings
# - Fireworks (vllm) for kimi-2.5-turbo unlimited usage

# --- OpenRouter (Primary - for Gemini models and embeddings) ---
LLM_OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
LLM_OPENAI_COMPATIBLE_API_KEY={{ env "OPENROUTER_API_KEY" }}

# --- Fireworks (VLLM provider - for kimi-2.5-turbo unlimited) ---
LLM_VLLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_VLLM_API_KEY={{ env "FIREWORKS_API_KEY" }}

# --- Embeddings (via OpenRouter) ---
LLM_EMBEDDING_PROVIDER=openrouter

# --- Summary Provider (OpenRouter -> Gemini) ---
SUMMARY__PROVIDER=custom
SUMMARY__MODEL=google/gemini-3-flash-lite-preview

# --- Deriver (Fireworks -> kimi-2.5-turbo unlimited) ---
DERIVER__PROVIDER=vllm
DERIVER__MODEL=accounts/fireworks/models/kimi-2.5-turbo
DERIVER__MAX_OUTPUT_TOKENS=4096
DERIVER__THINKING_BUDGET_TOKENS=2048

# ==============================================================================
# Dialectic Levels - Model Tiers
# ==============================================================================
# minimal/low/medium: OpenRouter -> Gemini models
# high/max: Fireworks -> kimi-2.5-turbo (unlimited)

# minimal level - OpenRouter -> gemini-3-flash-lite-preview
DIALECTIC__LEVELS__minimal__PROVIDER=custom
DIALECTIC__LEVELS__minimal__MODEL=google/gemini-3-flash-lite-preview
DIALECTIC__LEVELS__minimal__THINKING_BUDGET_TOKENS=256
DIALECTIC__LEVELS__minimal__MAX_OUTPUT_TOKENS=1024
DIALECTIC__LEVELS__minimal__MAX_TOOL_ITERATIONS=1

# low level - OpenRouter -> gemini-3-flash-lite-preview
DIALECTIC__LEVELS__low__PROVIDER=custom
DIALECTIC__LEVELS__low__MODEL=google/gemini-3-flash-lite-preview
DIALECTIC__LEVELS__low__THINKING_BUDGET_TOKENS=512
DIALECTIC__LEVELS__low__MAX_OUTPUT_TOKENS=2048
DIALECTIC__LEVELS__low__MAX_TOOL_ITERATIONS=2

# medium level - OpenRouter -> gemini-3-flash
DIALECTIC__LEVELS__medium__PROVIDER=custom
DIALECTIC__LEVELS__medium__MODEL=google/gemini-3-flash
DIALECTIC__LEVELS__medium__THINKING_BUDGET_TOKENS=1024
DIALECTIC__LEVELS__medium__MAX_OUTPUT_TOKENS=4096
DIALECTIC__LEVELS__medium__MAX_TOOL_ITERATIONS=3

# high level - Fireworks -> kimi-2.5-turbo (unlimited)
DIALECTIC__LEVELS__high__PROVIDER=vllm
DIALECTIC__LEVELS__high__MODEL=accounts/fireworks/models/kimi-2.5-turbo
DIALECTIC__LEVELS__high__THINKING_BUDGET_TOKENS=2048
DIALECTIC__LEVELS__high__MAX_OUTPUT_TOKENS=4096
DIALECTIC__LEVELS__high__MAX_TOOL_ITERATIONS=5

# max level - Fireworks -> kimi-2.5-turbo (unlimited)
DIALECTIC__LEVELS__max__PROVIDER=vllm
DIALECTIC__LEVELS__max__MODEL=accounts/fireworks/models/kimi-2.5-turbo
DIALECTIC__LEVELS__max__THINKING_BUDGET_TOKENS=2048
DIALECTIC__LEVELS__max__MAX_OUTPUT_TOKENS=4096
DIALECTIC__LEVELS__max__MAX_TOOL_ITERATIONS=10
