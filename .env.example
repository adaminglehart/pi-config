# =============================================================================
# pi-config environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and loaded automatically by mise.

# --- Work environment (LiteLLM proxy) ---
# Set these if you use a LiteLLM proxy for LLM access.
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_PROXY_HOST=

# --- Home environment (OpenRouter + Fireworks) ---
# Set these if you use OpenRouter and Fireworks directly.
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
