# =============================================================================
# pi-config environment variables
# =============================================================================
#
# OPTION 1: Use fnox for secret management (recommended)
# ---------------------------------------------------------
# Uses 1Password + age encryption for fast, secure secret access.
# 
# Setup:
#   1. Ensure fnox is installed: mise install fnox
#   2. Sync from 1Password: fnox sync --provider op --force
#   3. For fast cached access: fnox sync --provider age --force
#
# Loading secrets (choose one):
#   - Add to ~/.config/fish/user_conf.d/ (see dotfiles): fnox export --format env | source
#   - Or run before pi: eval "$(fnox export --format env)"
#   - Or add to your shell's rc file
#
# OPTION 2: Direct .env values (fallback)
# -----------------------------------------
# Copy this file to .env and fill in values directly (gitignored).
# Only used if secrets are not already set via fnox.

# --- WebSearch Extension ---
# PARALLEL_API_KEY - Required for websearch extension when using Parallel provider (default)
# Get your key at: https://platform.parallel.ai
PARALLEL_API_KEY=

# --- Work environment (LiteLLM proxy) ---
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_PROXY_HOST=

# --- Home environment (OpenRouter + Fireworks) ---
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
