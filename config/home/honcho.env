# ==============================================================================
# LLM Provider Configuration - HOME (OpenRouter + Fireworks ONLY)
# ==============================================================================
# NO direct OpenAI/Anthropic/Google API keys - everything routes through:
# - OpenRouter (primary) for Gemini models and embeddings
# - Fireworks (vllm) for kimi-k2p5-turbo via the Fireworks router

# --- OpenRouter (Primary - for Gemini models and embeddings) ---
LLM_OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
LLM_OPENAI_COMPATIBLE_API_KEY={{ env "OPENROUTER_API_KEY" }}

# --- Fireworks (VLLM provider - for kimi-2.5-turbo unlimited) ---
LLM_VLLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_VLLM_API_KEY={{ env "FIREWORKS_API_KEY" }}

# --- Embeddings (via OpenRouter) ---
LLM_EMBEDDING_PROVIDER=openrouter

# --- Summary Provider (OpenRouter -> Gemini) ---
SUMMARY_PROVIDER=custom
SUMMARY_MODEL=google/gemini-3.1-flash-lite-preview

# --- Deriver (Fireworks router -> kimi-k2p5-turbo) ---
DERIVER_PROVIDER=vllm
DERIVER_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
DERIVER_MAX_OUTPUT_TOKENS=4096
DERIVER_THINKING_BUDGET_TOKENS=2048

# ==============================================================================
# Dialectic Levels - Model Tiers
# ==============================================================================
# minimal/low/medium: OpenRouter -> Gemini models
# high/max: Fireworks router -> kimi-k2p5-turbo

# minimal level - OpenRouter -> gemini-3.1-flash-lite-preview
DIALECTIC_LEVELS__minimal__PROVIDER=custom
DIALECTIC_LEVELS__minimal__MODEL=google/gemini-3.1-flash-lite-preview
DIALECTIC_LEVELS__minimal__THINKING_BUDGET_TOKENS=256
DIALECTIC_LEVELS__minimal__MAX_OUTPUT_TOKENS=1024
DIALECTIC_LEVELS__minimal__MAX_TOOL_ITERATIONS=1

# low level - OpenRouter -> gemini-3.1-flash-lite-preview
DIALECTIC_LEVELS__low__PROVIDER=custom
DIALECTIC_LEVELS__low__MODEL=google/gemini-3.1-flash-lite-preview
DIALECTIC_LEVELS__low__THINKING_BUDGET_TOKENS=512
DIALECTIC_LEVELS__low__MAX_OUTPUT_TOKENS=2048
DIALECTIC_LEVELS__low__MAX_TOOL_ITERATIONS=2

# medium level - OpenRouter -> gemini-3-flash-preview
DIALECTIC_LEVELS__medium__PROVIDER=custom
DIALECTIC_LEVELS__medium__MODEL=google/gemini-3-flash-preview
DIALECTIC_LEVELS__medium__THINKING_BUDGET_TOKENS=1024
DIALECTIC_LEVELS__medium__MAX_OUTPUT_TOKENS=4096
DIALECTIC_LEVELS__medium__MAX_TOOL_ITERATIONS=3

# high level - Fireworks router -> kimi-k2p5-turbo
DIALECTIC_LEVELS__high__PROVIDER=vllm
DIALECTIC_LEVELS__high__MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
DIALECTIC_LEVELS__high__THINKING_BUDGET_TOKENS=2048
DIALECTIC_LEVELS__high__MAX_OUTPUT_TOKENS=4096
DIALECTIC_LEVELS__high__MAX_TOOL_ITERATIONS=5

# max level - Fireworks router -> kimi-k2p5-turbo
DIALECTIC_LEVELS__max__PROVIDER=vllm
DIALECTIC_LEVELS__max__MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
DIALECTIC_LEVELS__max__THINKING_BUDGET_TOKENS=2048
DIALECTIC_LEVELS__max__MAX_OUTPUT_TOKENS=4096
DIALECTIC_LEVELS__max__MAX_TOOL_ITERATIONS=10
