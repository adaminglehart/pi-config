{
  "lastChangelogVersion": "0.78.0",
  "packages": [
    "npm:glimpseui",
    // "git:github.com/HazAT/pi-interactive-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-subagents",
    "npm:pi-prompt-template-model",
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "thinking": "medium",
        "model": "openai-codex/gpt-5.3-codex-spark",
      },
      "researcher": {
        "model": "openai-codex/gpt-5.3-codex-spark",
        "tools": ["read", "write", "websearch", "webfetch", "intercom"],
      },
    },
  },
  "extensions": ["~/dev/plannotator/apps/pi-extension/index.ts"],
  "skills": ["~/.agents/skills"],
  "hideThinkingBlock": true,
  "quietStartup": true,
  "lcm": {
    "softTokenThreshold": 0.65,
    "hardTokenThreshold": 0.85,
    "backgroundCompaction": true,
  },
}
