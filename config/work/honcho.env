# ==============================================================================
# LLM Provider Configuration - WORK (Stripe LiteLLM Proxy)
# ==============================================================================
# Route all LLM calls through Stripe's LiteLLM proxy.

# --- OpenAI-Compatible Proxy (LiteLLM) ---
# Docker extra_hosts maps this hostname to host-gateway so containers reach certproxy on the host
LLM_OPENAI_COMPATIBLE_BASE_URL=http://litellm.qa.corp.stripe.com.certproxy.localhost:7891/v1
LLM_OPENAI_COMPATIBLE_API_KEY=use_case=development&team=privy-infra-data

# --- Embeddings ---
# Use "openai" provider which uses model "text-embedding-3-small" (matches our LiteLLM config)
# Set LLM_OPENAI_API_KEY for the embedding client, and OPENAI_BASE_URL so the OpenAI SDK
# routes through our LiteLLM proxy instead of api.openai.com
LLM_EMBEDDING_PROVIDER=openai
LLM_OPENAI_API_KEY=use_case=development&team=privy-infra-data
OPENAI_BASE_URL=http://litellm.qa.corp.stripe.com.certproxy.localhost:7891/v1

# --- Summary Provider ---
SUMMARY_PROVIDER=custom
SUMMARY_MODEL=gemini-3-flash

# --- Deriver (Reasoning) Provider ---
DERIVER_PROVIDER=custom
DERIVER_MODEL=claude-4.5-haiku

# Override dialectic levels to use the custom provider:
# minimal level - fast, cheap reasoning
DIALECTIC_LEVELS__minimal__PROVIDER=custom
DIALECTIC_LEVELS__minimal__MODEL=gemini-3-flash
DIALECTIC_LEVELS__minimal__THINKING_BUDGET_TOKENS=512
DIALECTIC_LEVELS__minimal__MAX_TOOL_ITERATIONS=1

# low level - lightweight reasoning
DIALECTIC_LEVELS__low__PROVIDER=custom
DIALECTIC_LEVELS__low__MODEL=gemini-3-flash
DIALECTIC_LEVELS__low__THINKING_BUDGET_TOKENS=1024
DIALECTIC_LEVELS__low__MAX_TOOL_ITERATIONS=2

# medium level - balanced reasoning
DIALECTIC_LEVELS__medium__PROVIDER=custom
DIALECTIC_LEVELS__medium__MODEL=claude-4.5-haiku
DIALECTIC_LEVELS__medium__THINKING_BUDGET_TOKENS=1024
DIALECTIC_LEVELS__medium__MAX_TOOL_ITERATIONS=2

# high level - deeper reasoning
DIALECTIC_LEVELS__high__PROVIDER=custom
DIALECTIC_LEVELS__high__MODEL=claude-sonnet-4.5
DIALECTIC_LEVELS__high__THINKING_BUDGET_TOKENS=2048
DIALECTIC_LEVELS__high__MAX_TOOL_ITERATIONS=5

# max level - maximum reasoning depth
DIALECTIC_LEVELS__max__PROVIDER=custom
DIALECTIC_LEVELS__max__MODEL=claude-sonnet-4.5
DIALECTIC_LEVELS__max__THINKING_BUDGET_TOKENS=4096
DIALECTIC_LEVELS__max__MAX_TOOL_ITERATIONS=10
