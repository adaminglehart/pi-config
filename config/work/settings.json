{
  "defaultProvider": "litellm-openai",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "litellm-anthropic/claude-opus-4-6",
    "litellm-anthropic/claude-opus-4.6-1m",
    "litellm-anthropic/claude-sonnet-4-6",
    "litellm-anthropic/claude-sonnet-4-6-1m",
    "litellm-anthropic/claude-4.5-haiku",
    "litellm-anthropic/claude-opus-4-7",
    "openai-codex/gpt-5.3-codex-spark",
    "litellm-openai/gpt-5.5",
    "litellm-openai/gpt-5.4",
    "litellm-google/gemini-3.1-pro",
    "litellm-google/gemini-3-flash"
  ],
  "librarian": {
    "maxTurns": 10,
    "maxSearchResults": 30,
    "models": "litellm-google/gemini-3-flash:medium,litellm-anthropic/claude-sonnet-4-6:high"
  },
  "compaction": {
    "provider": "litellm-google",
    "model": "gemini-3-flash"
  },
  "lcm": {
    "summaryProvider": "litellm-google",
    "summaryModel": "gemini-3-flash"
  },
  "subagents": {
    "agentOverrides": {
      "reviewer": {
        "model": "litellm-openai/gpt-5.5"
      }
    }
  }
}
