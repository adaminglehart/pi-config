{
  "name": "@pi/profile-coding",
  "private": true,
  "pi": {
    "destDir": "~/.pi/agent",
    "extensions": [
      "animations",
      "answer",
      "context-pilot",
      "cost",
      "custom-compaction",
      "custom-footer",
      "custom-startup-info",
      "dev-browser",
      "execute-command",
      "honcho",
      "lsp",
      "minimal-tools",
      "notify",
      "simplify",
      "todos",
      "tokens-per-second",
      "webfetch",
      "websearch"
    ],
    "skills": [
      "context-pilot",
      "msgvault-api",
      "pi-extension",
      "qmd-search",
      "session-reader"
    ],
    "vars": {
      "work": {
        "model.fast": "litellm-google/gemini-3-flash",
        "model.standard": "litellm-anthropic/claude-sonnet-4.5",
        "model.strong": "litellm-anthropic/claude-opus-4.6",
        "model.cheap": "litellm-anthropic/claude-4.5-haiku"
      },
      "home": {
        "model.fast": "accounts/fireworks/routers/kimi-k2p5-turbo",
        "model.standard": "accounts/fireworks/routers/kimi-k2p5-turbo",
        "model.strong": "openai-codex/gpt-5.4",
        "model.cheap": "accounts/fireworks/routers/kimi-k2p5-turbo"
      }
    }
  }
}
