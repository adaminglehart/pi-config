{
  "name": "@pi/profile-coding",
  "private": true,
  "pi": {
    "destDir": "~/.pi/agent",
    "extensions": [
      "animations",
      "answer",
      "cost",
      "custom-footer",
      // "lossless-context",
      "custom-compaction",
      "custom-startup-info",
      // "dev-browser",
      // "honcho",
      "hindsight",
      "lsp",
      "minimal-tools",
      "notify",
      "subagent",
      "todos",
      "tokens-per-second",
      "webfetch",
      "websearch",
    ],
    "skills": [
      "msgvault-api",
      "pi-extension",
      "session-reader",
      "agent-browser",
      "autoreview",
    ],
    "vars": {
      "work": {
        "model.fast": "litellm-google/gemini-3-flash",
        "model.standard": "litellm-anthropic/claude-sonnet-4-6",
        "model.strong": "litellm-openai/gpt-5.5",
        "model.reviewer": "litellm-openai/gpt-5.5",
        "model.cheap": "litellm-anthropic/claude-4.5-haiku",
      },
      "home": {
        "model.fast": "openrouter/qwen/qwen3-coder",
        "model.standard": "openrouter/qwen/qwen3-coder",
        "model.strong": "openai-codex/gpt-5.5",
        "model.reviewer": "openai-codex/gpt-5.5",
        "model.cheap": "openrouter/qwen/qwen3-coder",
      },
    },
  },
}
